# NetArchitect Ortam Değişkenleri
# Gerçek değerleri gizli tutmak için bu dosyayı .env olarak kopyalayın.

SECRET_KEY=django-insecure-replace-with-your-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,netarchitect.example.com

# Database
POSTGRES_DB=netarchitect
POSTGRES_USER=netarchitect
POSTGRES_PASSWORD=netarchitect
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery & Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Güvenlik & Webhook
WAZUH_API_KEY=your_webhook_api_key_here
WEBHOOK_ALLOWED_IPS=127.0.0.1,::1
VAULT_KEY=q2aL_h5d1WqL1eX_X7pX_P4Q8aZ9sV2xO3cT6nY0jM8=

# --- YENİ: PostgreSQL S3 Yedekleme ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BACKUP_BUCKET=netarchitect-backups
AWS_S3_REGION_NAME=eu-central-1
POSTGRES_BACKUP_DIR=/app/db_backups
POSTGRES_BACKUP_FORMAT=custom
POSTGRES_BACKUP_FILE_PREFIX=netarchitect_backup

# --- YENİ: Dağıtık Probe (Agent) ---
REMOTE_PROBE_SHARED_SECRET=your_super_secret_probe_key

# --- YENİ: SSO (Azure AD / OIDC / SAML) ---
# Azure AD
SOCIAL_AUTH_AZUREAD_OAUTH2_KEY=your_azure_client_id
SOCIAL_AUTH_AZUREAD_OAUTH2_SECRET=your_azure_client_secret
SOCIAL_AUTH_AZUREAD_OAUTH2_TENANT_ID=your_tenant_id

# OIDC (General)
SOCIAL_AUTH_OIDC_KEY=your_oidc_client_id
SOCIAL_AUTH_OIDC_SECRET=your_oidc_client_secret
SOCIAL_AUTH_OIDC_ENDPOINT=https://your-oidc-provider/.well-known/openid-configuration

# SAML (Opsiyonel)
SAML_METADATA_URL=https://idp.example.com/saml/metadata
SAML_ENTITY_ID=https://netarchitect.example.com/saml2/metadata/
SAML_ACS_URL=https://netarchitect.example.com/accounts/complete/saml/

# E-posta Ayarları
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMINS=Admin:admin@yourdomain.com